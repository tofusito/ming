GEMINI_API_KEY=replace-me
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter / Moonshot fallback:
# OPENROUTER_API_KEY=replace-me
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=moonshotai/kimi-k2.5:nitro
# OPENROUTER_SITE_URL=
# OPENROUTER_APP_NAME=Ming Translator
#
# Direct Moonshot fallback:
# MOONSHOT_API_KEY=replace-me
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.5
# KIMI_DISABLE_THINKING=true

STT_MODEL=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1
STT_VAD_FILTER=false
STT_INITIAL_PROMPT=The speaker may use Mandarin Chinese, Sichuan regional speech, Andalusian Spanish, family names, and colloquial expressions.

TTS_ENGINE=piper
TTS_ES_VOICE=es_ES-davefx-medium
TTS_ZH_VOICE=zh_CN-chaowen-medium
TTS_PIPER_DOWNLOAD_DIR=/root/.local/share/piper
